generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id              String    @id
  name            String
  date            String?
  active          Boolean?  @default(false)
  jurorCount      Int?      @default(0) @map("juror_count")
  config          Json
  resultsVisible  Boolean?  @default(false) @map("results_visible")
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  answers         Answer[]

  @@map("sessions")
}

model Answer {
  id        BigInt    @id @default(autoincrement())
  sessionId String    @map("session_id")
  jurorName String    @map("juror_name")
  data      Json      @default("{}")
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  session   Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([sessionId, jurorName])
  @@map("answers")
}
